local VerifyButton = Instance.new("TextButton")
VerifyButton.Size = UDim2.new(1, -40, 0, 45)
VerifyButton.Position = UDim2.new(0, 20, 0, 150)
VerifyButton.BackgroundColor3 = Color3.fromRGB(55, 120, 250)
VerifyButton.Text = "開始驗證"
VerifyButton.TextColor3 = Color3.fromRGB(255, 255, 255)
VerifyButton.TextSize = 16
VerifyButton.Font = Enum.Font.GothamBold
VerifyButton.BorderSizePixel = 0
VerifyButton.Parent = MainFrame

local BtnCorner = Instance.new("UICorner")
BtnCorner.CornerRadius = UDim.new(0, 8)
BtnCorner.Parent = VerifyButton

VerifyButton.Activated:Connect(function()
    local inputKey = TextBox.Text
    if inputKey == "" then
        VerifyButton.Text = "❌ 請先輸入卡密！"
        task.wait(1.5)
        VerifyButton.Text = "開始驗證"
        return
    end
    
    VerifyButton.Text = "⚡ 正在穿透連線中..."
    VerifyButton.Active = false
    
    -- 🚀 使用最安全的 game:HttpGet 備用繞過機制，將參數直接掛在網址後面
    local fullUrl = BACKEND_URL .. "?key=" .. HttpService:UrlEncode(inputKey)
    
    local success, resBody = pcall(function()
        return game:HttpGet(fullUrl)
    end)
    
    if success and resBody then
        local decodeSuccess, data = pcall(function() return HttpService:JSONDecode(resBody) end)
        
        if decodeSuccess and data.success then
            VerifyButton.Text = "✅ 歡迎，" .. tostring(data.user) .. "！載入中..."
            VerifyButton.BackgroundColor3 = Color3.fromRGB(46, 204, 113)
            task.wait(1)
            ScreenGui:Destroy()
            
            if data.scriptData then
                local runScript, compileError = loadstring(data.scriptData)
                if runScript then 
                    pcall(runScript) 
                else 
                    warn("[Iruka Hub] 編譯失敗: " .. tostring(compileError)) 
                end
            end
        else
            local errMsg = data and data.message or "卡密不正確"
            VerifyButton.Text = "❌ " .. tostring(errMsg)
            VerifyButton.BackgroundColor3 = Color3.fromRGB(231, 76, 60)
        end
    else
        VerifyButton.Text = "❌ 連線失敗: 網址不正確或伺服器未開啟"
        VerifyButton.BackgroundColor3 = Color3.fromRGB(231, 76, 60)
        warn("Roblox Http 錯誤訊息: " .. tostring(resBody))
    end
    
    task.wait(2)
    VerifyButton.BackgroundColor3 = Color3.fromRGB(55, 120, 250)
    VerifyButton.Text = "開始驗證"
    VerifyButton.Active = true
end)
