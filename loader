-- ==========================================
-- 🚀 後端中轉驗證發送邏輯
-- ==========================================
VerifyButton.MouseButton1Click:Connect(function()
    local inputKey = TextBox.Text
    if inputKey == "" then
        VerifyButton.Text = "❌ 請先輸入卡密！"
        task.wait(1.5)
        VerifyButton.Text = "開始驗證"
        return
    end
    
    VerifyButton.Text = "⚡ 正在與 Vercel 安全連線..."
    VerifyButton.Active = false
    
    local payload = {
        key = inputKey,
        userId = tostring(LocalPlayer.UserId)
    }
    
    local jsonPayload = HttpService:JSONEncode(payload)
    -- 自動適應所有執行器的請求函式
    local sendRequest = syn and syn.request or http and http.request or request
    
    if not sendRequest then
        VerifyButton.Text = "❌ 您的執行器不支援安全 HTTP 請求"
        task.wait(2)
        VerifyButton.Text = "開始驗證"
        VerifyButton.Active = true
        return
    end

    local success, res = pcall(function()
        return sendRequest({
            Url = BACKEND_URL,
            Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = jsonPayload
        })
    end)
    
    if success and res.Body then
        local decodeSuccess, data = pcall(function() return HttpService:JSONDecode(res.Body) end)
        
        if decodeSuccess and data.success then
            VerifyButton.Text = "✅ 驗證成功！正在加載核心..."
            VerifyButton.BackgroundColor3 = Color3.fromRGB(46, 204, 113)
            task.wait(0.5)
            ScreenGui:Destroy()
            
            -- 🔒 核心安全改動：直接從後台記憶體數據執行，不經由網路網址
            if data.scriptData then
                local runScript, compileError = loadstring(data.scriptData)
                if runScript then 
                    local runSuccess, runError = pcall(runScript)
                    if not runSuccess then
                        warn("[Iruka Hub] 執行本體時發生錯誤: " .. tostring(runError))
                    end
                else 
                    warn("[Iruka Hub] 腳本編譯失敗: " .. tostring(compileError)) 
                end
            else
                warn("[Iruka Hub] 後端未傳回核心腳本數據")
            end
        else
            local errMsg = data and data.message or "卡密不正確"
            VerifyButton.Text = "❌ " .. tostring(errMsg)
            VerifyButton.BackgroundColor3 = Color3.fromRGB(231, 76, 60)
            task.wait(2)
            VerifyButton.BackgroundColor3 = Color3.fromRGB(55, 120, 250)
            VerifyButton.Text = "開始驗證"
            VerifyButton.Active = true
        end
    else
        VerifyButton.Text = "❌ 無法連線至 Vercel 伺服器"
        VerifyButton.BackgroundColor3 = Color3.fromRGB(231, 76, 60)
        task.wait(2)
        VerifyButton.BackgroundColor3 = Color3.fromRGB(55, 120, 250)
        VerifyButton.Text = "開始驗證"
        VerifyButton.Active = true
    end
end)
