-- ========================================
-- + / - 按鈕：調整速度倍率
-- ========================================
plus.MouseButton1Down:connect(function()
	speeds = speeds + 1
	speed.Text = speeds
	if nowe then restartWalk() end
end)

mine.MouseButton1Down:connect(function()
	if speeds == 1 then
		speed.Text = "最小值為 1"
		wait(1)
		speed.Text = speeds
	else
		speeds = speeds - 1
		speed.Text = speeds
		if nowe then restartWalk() end
	end
end)

-- 速度框直接輸入
speed.FocusLost:Connect(function()
	local newSpeed = tonumber(speed.Text)
	if newSpeed and newSpeed > 0 then
		speeds = newSpeed
		if nowe then restartWalk() end
	elseif newSpeed and newSpeed < 1 then
		speed.Text = "最小值為 1"
		wait(1)
		speed.Text = speeds
	else
		speed.Text = "無效數值"
		wait(1)
		speed.Text = speeds
	end
end)

