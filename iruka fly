local function createButton(name, parent, size, pos, text, bgColor, textColor, textSize)
	local btn = Instance.new("TextButton")
	btn.Name = name
	btn.Parent = parent
	btn.Size = size
	btn.Position = pos
	btn.Text = text
	btn.Font = Enum.Font.RobotoMono
	btn.TextColor3 = textColor
	btn.TextSize = textSize
	btn.BackgroundColor3 = bgColor
	btn.BackgroundTransparency = 0.1
	addUICorner(btn, 8)
	return btn
end

