-- ━━━━━━━━━━━━━━━━━━━━━━ 核心循環 ━━━━━━━━━━━━━━━━━━━━━━
local function getRef()
    character = player.Character
    if character then
        hrp = character:FindFirstChild("HumanoidRootPart")
        humanoid = character:FindFirstChild("Humanoid")
    end
end

RunService.Heartbeat:Connect(function()
    getRef()
    if hrp then doFastAttack() end
end)

task.spawn(function()
    while true do
        task.wait(0.8)
        if not sg.Parent then break end
        getRef()
        if not character then continue end
        
        if State.AutoBuso and not character:FindFirstChild("HasBuso") then
            pcall(function() ReplicatedStorage.Remotes.CommF_:InvokeServer("Buso") end)
        end
        if State.AutoV3 then
            pcall(function() ReplicatedStorage.Remotes.CommE:FireServer("ActivateAbility") end)
        end
        if State.AutoV4 then
            local awk = player.Backpack:FindFirstChild("Awakening") or character:FindFirstChild("Awakening")
            if awk and awk:FindFirstChild("RemoteFunction") then
                pcall(function() awk.RemoteFunction:InvokeServer(true) end)
            end
        end
        if State.AutoBuddha and humanoid and humanoid.HipHeight <= CONFIG.BUDDHA_HIP then
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Two, false, nil)
            task.wait(0.5)
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Z, false, nil)
            task.wait(1.5)
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Three, false, nil)
        end
    end
end)
