}

-- ━━━━━━━━━━━━━━━━━━━━━━ Fast Attack 邏輯 ━━━━━━━━━━━━━━━━━━━━━━
local Net = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Net")
local RegisterAttack = Net:WaitForChild("RE/RegisterAttack")
local RegisterHit = Net:WaitForChild("RE/RegisterHit")

local lastAttackTime = 0
local lastScanTime = 0
local cachedBladeHits = {}

local function getTargets()
    if tick() - lastScanTime < 0.01 and #cachedBladeHits > 0 then return cachedBladeHits end
    local targets = {}
    local playerPos = hrp and hrp.Position
    if not playerPos then return targets end
    
    local function scan(folder)
        if not folder then return end
        for _, v in pairs(folder:GetChildren()) do
            if v:FindFirstChild("HumanoidRootPart") and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                if (v.HumanoidRootPart.Position - playerPos).Magnitude <= CONFIG.AttackDistance then
                    table.insert(targets, v)
                end
            end
        end
    end
    scan(workspace:FindFirstChild("Enemies"))
    scan(workspace:FindFirstChild("Characters"))
    lastScanTime = tick()
    cachedBladeHits = targets
    return targets
end

local function doFastAttack()
    if not State.AutoFastAttack or (tick() - lastAttackTime) < CONFIG.AttackCooldown then return end
    lastAttackTime = tick()
    local enemies = getTargets()
    if #enemies > 0 then
        RegisterAttack:FireServer(-math.huge)
        local args = {nil, {}}
        for i, v in pairs(enemies) do
            if not args[1] then args[1] = v:FindFirstChild("Head") or v.HumanoidRootPart end
            args[2][i] = {v, v.HumanoidRootPart}
        end
        RegisterHit:FireServer(unpack(args))
    end
end

