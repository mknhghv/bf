-- 創建按鈕
local function makeBtn(txt, y, stateKey, colorOn)
    local b = Instance.new("TextButton", main)
    b.Size = UDim2.new(0.92, 0, 0, 55)
    b.Position = UDim2.new(0.04, 0, 0, y)
    b.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
    b.Text = txt
    b.TextColor3 = Color3.new(1, 1, 1)
    b.TextSize = 22
    Instance.new("UICorner", b)
    b.MouseButton1Click:Connect(function()
        State[stateKey] = not State[stateKey]
        b.BackgroundColor3 = State[stateKey] and colorOn or Color3.fromRGB(60, 60, 80)
    end)
end

-- 創建輸入調整框 (打字用)
local function makeInput(txt, y, callback)
    local label = Instance.new("TextLabel", main)
    label.Size = UDim2.new(0.5, 0, 0, 40)
    label.Position = UDim2.new(0.04, 0, 0, y)
    label.Text = txt
    label.TextColor3 = Color3.new(0.8, 0.8, 0.8)
    label.TextSize = 20
    label.BackgroundTransparency = 1
    label.TextXAlignment = Enum.TextXAlignment.Left

    local box = Instance.new("TextBox", main)
    box.Size = UDim2.new(0.4, 0, 0, 40)
    box.Position = UDim2.new(0.56, 0, 0, y)
    box.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    box.TextColor3 = Color3.new(1, 1, 1)
    box.TextSize = 20
    box.PlaceholderText = "輸入數值"
    Instance.new("UICorner", box)
    
    box.FocusLost:Connect(function()
        local val = tonumber(box.Text)
        if val then callback(val) updateUI() end
        box.Text = ""
    end)
end

