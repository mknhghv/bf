-- ━━━━━━━━━━━━━━━━━━━━━━ 核心設定 ━━━━━━━━━━━━━━━━━━━━━━
local CONFIG = {
    BUDDHA_HIP = 10,
    AttackDistance = 5000,
    AttackCooldown = 0.05,
    MaxZoom = 128
}

